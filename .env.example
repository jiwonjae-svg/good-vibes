# =============================================================================
# DailyGlow - Environment Variables Example
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual values in .env
#   3. NEVER commit .env to git (it is already in .gitignore)
#
# EXPO RULE:
#   Any variable exposed to client (React Native) code MUST be prefixed with
#   EXPO_PUBLIC_  (e.g. EXPO_PUBLIC_GROK_API_KEY)
#   Variables WITHOUT this prefix are only available in server/build scripts.
# =============================================================================


# -----------------------------------------------------------------------------
# Grok AI (xAI)
# -----------------------------------------------------------------------------
# Where to get it:
#   1. Sign up at https://console.x.ai/
#   2. Go to API Keys section
#   3. Create a new API key
#   4. Copy the key value (it starts with "xai-")
#
# Docs: https://docs.x.ai/docs
# -----------------------------------------------------------------------------
EXPO_PUBLIC_GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The model to use. Check available models at https://docs.x.ai/docs/models
EXPO_PUBLIC_GROK_MODEL=grok-4-1-fast-non-reasoning


# -----------------------------------------------------------------------------
# Firebase (Web SDK)
# -----------------------------------------------------------------------------
# Where to get it:
#   1. Go to https://console.firebase.google.com/
#   2. Select your project (or create one)
#   3. Click the gear icon → Project Settings
#   4. Scroll down to "Your apps" → Web app (</> icon)
#   5. Register the app if you haven't; copy the firebaseConfig object values
#
# Docs: https://firebase.google.com/docs/web/setup
#
# NOTE: Firebase API keys are NOT secret in the traditional sense — they are
#       client-side identifiers protected by Firebase Security Rules. However,
#       keeping them in .env prevents accidental exposure in public repos.
# -----------------------------------------------------------------------------
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:xxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Google OAuth Client IDs (required for Google Sign-In)
# -----------------------------------------------------------------------------
# Where to get them:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Select your project (same project as Firebase)
#   3. Click "CREATE CREDENTIALS" → "OAuth client ID"
#
# WEB CLIENT (required — used for redirect flow):
#   - Application type: "Web application"
#   - Authorized JavaScript origins: https://auth.expo.io
#   - Authorized redirect URIs:
#       • https://auth.expo.io/@your-expo-username/dailyglow
#       • com.jiwonjae.dailyglow:/oauth2redirect (for standalone builds)
#   - Copy the Client ID (ends with .apps.googleusercontent.com)
#
# iOS CLIENT:
#   - Application type: "iOS"
#   - Bundle ID: com.jiwonjae.dailyglow
#   - Copy the Client ID
#
# ANDROID CLIENT:
#   - Application type: "Android"
#   - Package name: com.jiwonjae.dailyglow
#   - SHA-1 certificate fingerprint: (see instructions below)
#       For debug builds (Windows): keytool -list -v -keystore "%USERPROFILE%\.android\debug.keystore" -alias androiddebugkey -storepass android
#       For EAS builds: eas credentials --platform android
#   - Copy the Client ID
#
# IMPORTANT: Also add the Web Client ID to Firebase Console:
#   1. Go to Firebase Console → Authentication → Sign-in method
#   2. Enable Google provider
#   3. Add your Web Client ID and Secret
#
# Docs: https://docs.expo.dev/guides/google-authentication/
# -----------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=123456789012-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=123456789012-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=123456789012-zzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzzz.apps.googleusercontent.com


# -----------------------------------------------------------------------------
# Google AdMob (optional)
# -----------------------------------------------------------------------------
# Where to get it:
#   1. Go to https://admob.google.com/
#   2. Sign in with your Google account
#   3. Apps → Add App (or select existing)
#   4. Ad Units → Create Ad Unit → Interstitial
#   5. Copy the Ad Unit ID (format: ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX)
#
# Docs: https://developers.google.com/admob/android/quick-start
#
# The default values below are Google's official TEST ad unit IDs.
# Replace with your real production IDs before publishing.
# -----------------------------------------------------------------------------
EXPO_PUBLIC_AD_UNIT_ANDROID=ca-app-pub-3940256099942544/1033173712
EXPO_PUBLIC_AD_UNIT_IOS=ca-app-pub-3940256099942544/4411468910
