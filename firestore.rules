rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 기존 컬렉션 ─────────────────────────────────────────────────────

    // 서버 명언 카탈로그: 공개 읽기 전용
    match /quotes_catalog/{doc} {
      allow read: if true;
      allow write: if false;
    }

    // 사용자 데이터:
    //   - 읽기: 인증된 모든 사용자 (공개 프로필 지원)
    //   - 생성/삭제: 본인만
    //   - 업데이트: 본인이거나, followerCount만 ±1 변경인 경우 허용
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId)
        || (request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount'])
            && (request.resource.data.followerCount == resource.data.followerCount + 1
                || request.resource.data.followerCount == resource.data.followerCount - 1))
        || (request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followingCount'])
            && (request.resource.data.followingCount == resource.data.followingCount + 1
                || request.resource.data.followingCount == resource.data.followingCount - 1));
    }

    // 사용자명 인덱스: 누구나 읽기(가용성 확인), 본인 uid로만 생성/삭제
    match /usernames/{username} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── 커뮤니티 기능 ────────────────────────────────────────────────────

    // community_quotes: 누구나 읽기; 인증 사용자만 생성
    // 작성자가 text/author/updatedAt 수정 가능, 삭제 가능
    // likeCount: 인증 사용자가 ±1만 수정 가능 (클라이언트 denormalized counter)
    // reportCount: 인증 사용자가 +1만 허용 (신고 시)
    match /community_quotes/{quoteId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.status in ['pending', 'approved']
        && request.resource.data.submitterId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 10
        && request.resource.data.text.size() <= 500;

      // 작성자 편집: text/author/updatedAt만 수정 허용
      // reportCount +1만 허용 (신고 시)
      allow update: if request.auth != null
        && (
          (
            resource.data.submitterId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'author', 'updatedAt'])
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount'])
            && request.resource.data.reportCount == resource.data.reportCount + 1
          )
        );

      // 작성자만 삭제 가능
      allow delete: if request.auth != null
        && resource.data.submitterId == request.auth.uid;
    }

    // community_likes: 인증 사용자가 자기 좋아요만 쓰기/삭제
    // 문서 ID 규칙: {userId}_{quoteId}
    match /community_likes/{likeId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && likeId.matches(request.auth.uid + '_.*')
        && request.resource.data.userId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow update: if false;
    }

    // community_reports: 인증 사용자가 자기 신고만 생성, 수정/삭제 불가
    // 문서 ID 규칙: {userId}_{quoteId}
    match /community_reports/{reportId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
        && reportId.matches(request.auth.uid + '_.*')
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.reason is string;

      allow update, delete: if false;
    }

    // follows: 인증 사용자가 자기 팔로우만 생성/삭제
    // 문서 ID 규칙: {followerId}_{followingId}
    match /follows/{followId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.followerId == request.auth.uid;

      allow delete: if request.auth != null
        && resource.data.followerId == request.auth.uid;

      allow update: if false;
    }

    // 팔로우 알림: 수신자 본인이 읽기/read 업데이트; 인증 사용자가 생성(발송); 발신자 또는 수신자가 삭제
    // 경로: users/{userId}/notifications/{notifId}  (notifId = "follow_{senderUid}")
    match /users/{userId}/notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null;

      // 수신자는 read 필드만 true 로 업데이트 가능
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;

      // 수신자 또는 발신자(unfollow 시)가 삭제 가능
      allow delete: if request.auth != null
        && (request.auth.uid == userId
            || resource.data.fromUid == request.auth.uid);
    }

    // ── 사용자 서브컬렉션 ────────────────────────────────────────────────

    // 오늘/날짜별 열람 명언 + 북마크: 본인만 읽기/쓰기
    // 경로: users/{uid}/quoteHistory/{YYYY-MM-DD | "bookmarked"}
    match /users/{userId}/quoteHistory/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 활동 잔디 기록: 본인만 읽기/쓰기
    // 경로: users/{uid}/grassHistory/{YYYY-MM-DD}
    match /users/{userId}/grassHistory/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── 로그 / 평가 / 신고 컬렉션 ────────────────────────────────────────

    // activities: 인증 사용자가 자기 uid로만 생성 (로그인·명언 열람 등 이벤트 로깅)
    match /activities/{docId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // reports: 인증 사용자가 자기 uid로만 신고 생성, 수정/삭제 불가
    match /reports/{docId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // quoteRatings: 자기 평가만 읽기/쓰기
    // 문서 ID 규칙: {uid}_{quoteId}
    match /quoteRatings/{ratingId} {
      allow read, write: if request.auth != null
        && ratingId.matches(request.auth.uid + '_.*');
    }
  }
}
