{
  "name": "dailyglow",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "eas-build-post-install": "node scripts/setup-google-services.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android:local": "eas build --local --platform android --profile preview",
    "build:android:wsl": "powershell -ExecutionPolicy Bypass -File ./scripts/build-android-wsl.ps1",
    "prepare": "husky",
    "check:secrets": "node scripts/check-secrets.js",
    "check:env": "node -e \"require('./constants/config.ts')\" || echo 'Run: npx ts-node constants/config.ts'"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "node scripts/check-secrets.js"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^23.8.6",
    "@sentry/react-native": "~7.2.0",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-av": "^16.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-navigation-bar": "~5.0.10",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^12.9.0",
    "i18next": "^25.8.13",
    "moti": "^0.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-view-shot": "^4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "firebase-admin": "^13.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "~5.9.2"
  },
  "private": true
}
